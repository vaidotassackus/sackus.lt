---
import Layout from "../layouts/Layout.astro";
import FamilyTree from "../components/FamilyTree.vue";
import people from "../data/people.json";
import couples from "../data/couples.json";
import generations from "../data/generations.json";
import type { People, Couple, Generation } from "../types/person";
---

<Layout title="Šačkus — Giminės Medis" bodyClass="tree-page">
  <FamilyTree
    client:load
    people={people as People}
    couples={couples as Couple[]}
    generations={generations as Generation[]}
  />
</Layout>
